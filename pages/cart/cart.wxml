<view class="container cart-page"><view class="head card"><view class="head-copy"><view class="title">{{t.title}}</view><view class="muted">{{t.subtitle}}</view></view><view class="badge count-badge">{{cartCount}} {{t.portion}}</view></view><view class="section-title"><text>{{t.pickedRecipes}}</text></view><view class="card list-card"><view wx:if="{{!items.length}}" class="empty">{{t.emptyHint}}</view><view wx:for="{{items}}" wx:key="id" class="cart-item"><view class="cover">{{item.cover}}</view><view class="item-main"><view class="item-name">{{item.name}}</view><view class="muted desc">{{item.desc}}</view></view><view class="counter"><view class="counter-btn minus" data-id="{{item.id}}" bindtap="minus">-</view><text class="quantity">{{item.quantity}}</text><view class="counter-btn plus" data-id="{{item.id}}" bindtap="add">+</view></view></view></view><view class="section-title"><text>{{t.remark}}</text></view><textarea class="remark card" placeholder="{{t.placeholder}}" value="{{remark}}" bindinput="onRemark" /><view class="submit-bar"><view class="submit-copy"><view class="submit-title">{{cartCount}} {{t.items}}</view><view class="muted one-line">{{t.doubleConfirm}}</view></view><button class="primary-btn submit-btn" bindtap="submitOrder">{{t.submit}}</button></view></view>
