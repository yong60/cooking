.hero { display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx; padding: 32rpx; background: linear-gradient(145deg,#fff,#fff1e4); }
.hero-copy { flex: 1; min-width: 0; }
.title { font-size: 42rpx; font-weight: 950; }
.empty-card { margin-top: 28rpx; padding: 70rpx 34rpx; text-align: center; }
.empty-icon { font-size: 90rpx; }
.empty-title { margin: 18rpx 0 10rpx; font-size: 34rpx; font-weight: 950; }
.empty-btn { margin-top: 34rpx; }
.login-empty { padding-left: 44rpx; padding-right: 44rpx; }
.empty-hint { max-width: 520rpx; margin: 0 auto; }
.selected-list { display: flex; flex-wrap: wrap; gap: 14rpx; }
.chip { position: relative; max-width: 320rpx; min-height: 58rpx; display: inline-flex; align-items: center; gap: 10rpx; box-sizing: border-box; padding: 10rpx 10rpx 10rpx 18rpx; border-radius: 999rpx; background: #fff; color: #5a4032; font-size: 25rpx; font-weight: 800; box-shadow: 0 8rpx 18rpx rgba(155, 91, 37, .07); }
.chip-text { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.chip-close { width: 38rpx; height: 38rpx; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; border-radius: 50%; color: #fff; background: #ff6b35; font-size: 28rpx; line-height: 38rpx; }
.option-card { padding: 28rpx; }
.option-title { font-size: 30rpx; font-weight: 900; }
.count-row { display: flex; gap: 12rpx; margin-top: 20rpx; }
.count-btn { flex: 1; min-width: 0; height: 72rpx; display: flex; align-items: center; justify-content: center; line-height: 72rpx; text-align: center; border-radius: 22rpx; color: #8a6d5a; background: #fff4ec; font-size: 26rpx; font-weight: 800; white-space: nowrap; }
.count-btn.active { color: #fff; background: #ff5a1f; }
.soup-row { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; margin-top: 30rpx; padding-top: 28rpx; border-top: 1rpx solid #f3ede7; }
.soup-copy { flex: 1; min-width: 0; }
.generate-btn { margin-top: 30rpx; align-items: center; line-height: 88rpx; text-align: center; }
.recommend-card { display: flex; align-items: center; gap: 18rpx; padding: 22rpx; margin-bottom: 18rpx; }
.cover { width: 96rpx; height: 96rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border-radius: 26rpx; color:#ff5a1f; background: linear-gradient(145deg,#fff7ee,#ffe6d1); font-size: 34rpx; font-weight:950; }
.main { flex: 1; min-width: 0; }
.name { font-size: 30rpx; font-weight: 900; }
.tags { display: flex; gap: 10rpx; margin-top: 12rpx; flex-wrap: wrap; }
.add-small { flex-shrink: 0; padding: 0 22rpx; }
