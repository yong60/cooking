.user-card { display: flex; align-items: center; gap: 22rpx; padding: 32rpx; background: linear-gradient(145deg, #fff, #fff0e4 70%, #ffe0c5); }
.avatar { width: 112rpx; height: 112rpx; border-radius: 36rpx; flex-shrink: 0; }
.text-avatar { display: flex; align-items: center; justify-content: center; color: #ff5a1f; background: #fff; font-size: 54rpx; font-weight: 950; box-shadow: inset 0 0 0 2rpx #ffe2cc; }
.user-info { flex: 1; min-width: 0; }
.login-mode { gap: 16rpx; padding: 26rpx 24rpx; }
.login-mode .avatar { width: 88rpx; height: 88rpx; border-radius: 28rpx; }
.login-mode .user-name { font-size: 31rpx; white-space: nowrap; }
.login-mode .muted { font-size: 23rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.login-mode .profile-subtitle { display: none; }
.user-name { font-size: 36rpx; font-weight: 950; }
.profile-subtitle { margin-top: 8rpx; color: #9b6544; font-size: 23rpx; }
.login-btn { width: 200rpx; min-width: 200rpx; max-width: 200rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; padding: 0; border-radius: 999rpx; color: #fff; background: #ff5a1f; font-size: 24rpx; line-height: 64rpx; font-weight: 900; text-align: center; white-space: nowrap; }
.stats { display: flex; margin-top: 22rpx; padding: 28rpx 0; }
.stat-item { flex: 1; text-align: center; border-right: 1rpx solid #f1e8df; }
.stat-item:active { background: rgba(255,240,229,.55); }
.stat-item:last-child { border-right: 0; }
.stat-num { margin-bottom: 8rpx; color: #ff5a1f; font-size: 48rpx; font-weight: 950; }
.edit-card, .bind-card { display: flex; flex-direction: column; gap: 18rpx; padding: 26rpx; }
.avatar-edit { display: flex; align-items: center; gap: 18rpx; }
.edit-avatar { width: 96rpx; height: 96rpx; border-radius: 30rpx; flex-shrink: 0; }
.avatar-btn { flex-shrink: 0; }
.save-profile { height: 78rpx; }
.mode-line { color: #ff5a1f; font-size: 28rpx; font-weight: 900; }
.join-card { margin-bottom: 18rpx; padding: 28rpx; background: linear-gradient(145deg,#fff,#fff0e5); }
.join-title { margin-bottom: 8rpx; color: #ff5a1f; font-size: 31rpx; font-weight: 950; }
.join-btn { margin-top: 18rpx; height: 66rpx; display: flex; align-items: center; justify-content: center; border-radius: 999rpx; color: #fff; background: linear-gradient(135deg,#ff9b3d,#ff5725); font-size: 27rpx; font-weight: 950; }
.id-box { display: flex; align-items: flex-start; justify-content: space-between; gap: 16rpx; padding: 18rpx 20rpx; border-radius: 22rpx; background: #fff7ee; color: #8a6753; font-size: 24rpx; }
.id-text { flex: 1; min-width: 0; text-align: right; word-break: break-all; color: #342820; font-weight: 800; }
.bind-actions { display: flex; gap: 16rpx; }
.bind-btn { flex: 1; height: 78rpx; }
.share-btn { height: 78rpx; flex-shrink: 0; }
.unbind-btn { width: 100%; height: 70rpx; }
.action-list { padding: 4rpx 28rpx; }
.action-row { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 20rpx; padding: 30rpx 0; border-bottom: 1rpx solid #f4eee8; font-size: 30rpx; font-weight: 900; text-align: left; color: #342820; white-space: nowrap; }
.action-row:last-child { border-bottom: 0; }

.row-arrow { width: 16rpx; height: 16rpx; flex-shrink: 0; border-top: 4rpx solid #d8a184; border-right: 4rpx solid #d8a184; transform: rotate(45deg); }
