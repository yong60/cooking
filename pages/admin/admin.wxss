.admin-page { padding-bottom: calc(210rpx + env(safe-area-inset-bottom)); }
.admin-head { padding: 34rpx; background: linear-gradient(145deg,#fff,#fff1e4); }
.title { font-size: 44rpx; font-weight: 950; }
.empty { margin-top: 26rpx; padding: 70rpx 34rpx; text-align: center; }
.empty-title { color: #8a6753; font-size: 30rpx; font-weight: 900; line-height: 1.6; }
.tabs { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin-top: 24rpx; padding: 12rpx; }
.tab { height: 72rpx; display: flex; align-items: center; justify-content: center; text-align: center; border-radius: 24rpx; color: #8a6753; font-size: 28rpx; font-weight: 900; }
.tab.active { color: #fff; background: linear-gradient(135deg,#ff9b3d,#ff5725); box-shadow: 0 10rpx 22rpx rgba(255,90,31,.18); }
.add-btn { margin: 24rpx 0; }
.form-card { display: flex; flex-direction: column; gap: 18rpx; padding: 24rpx; margin-bottom: 24rpx; }
.inline-form { margin-top: -6rpx; }
.expand-card { animation: adminExpand .22s ease-out both; transform-origin: top center; }
@keyframes adminExpand {
  from { opacity: 0; transform: translateY(-12rpx) scaleY(.96); }
  to { opacity: 1; transform: translateY(0) scaleY(1); }
}
.form-title { color: #342820; font-size: 32rpx; font-weight: 950; }
.field-label { margin-top: 6rpx; color: #5b4437; font-size: 27rpx; font-weight: 900; }
.hint { color: #9a8272; font-size: 23rpx; line-height: 1.45; }
.choice-wrap { display: flex; flex-wrap: wrap; gap: 12rpx; }
.choice-chip { max-width: 100%; min-height: 56rpx; box-sizing: border-box; display: inline-flex; align-items: center; justify-content: center; padding: 0 20rpx; border-radius: 999rpx; color: #8a6753; background: #fff7ef; font-size: 24rpx; font-weight: 850; }
.choice-chip.active { color: #fff; background: linear-gradient(135deg,#ff9b3d,#ff5725); box-shadow: 0 8rpx 18rpx rgba(255,90,31,.18); }
.advanced-toggle { height: 62rpx; display: flex; align-items: center; justify-content: center; border-radius: 999rpx; color: #e65b20; background: #fff0e7; font-size: 25rpx; font-weight: 900; }
.advanced-box { display: flex; flex-direction: column; gap: 16rpx; padding: 18rpx; border-radius: 26rpx; background: #fffaf6; }
.form-actions { display: flex; justify-content: flex-end; gap: 18rpx; margin-top: 4rpx; }
.save-btn { width: 190rpx; height: 72rpx; }
.data-card { width: 100%; box-sizing: border-box; display: flex; align-items: center; gap: 16rpx; padding: 20rpx; margin-bottom: 18rpx; }
.data-cover { width: 96rpx; height: 96rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border-radius: 26rpx; color: #ff5a1f; background: linear-gradient(145deg,#fff7ee,#ffe6d1); font-size: 38rpx; font-weight: 950; overflow: hidden; }
.image-cover { background: #fff1e4; }
.data-main { flex: 1; min-width: 0; }
.data-title { font-size: 30rpx; font-weight: 950; line-height: 1.25; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.data-desc { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.chips { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 10rpx; }
.ops { width: 92rpx; display: flex; flex-direction: column; gap: 10rpx; flex-shrink: 0; }
.mini-btn { width: 92rpx; height: 48rpx; box-sizing: border-box; display: flex; align-items: center; justify-content: center; padding: 0; text-align: center; border-radius: 999rpx; color: #ff5a1f; background: #fff0e7; font-size: 22rpx; font-weight: 900; }
.mini-btn.danger { color: #d83b20; background: #fff0ec; }
