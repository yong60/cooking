<view class="ingredients-page">
  <view class="top card">
    <view class="top-copy">
      <view class="title">{{t.title}}</view>
      <view class="muted">{{t.subtitle}}</view>
    </view>
    <view class="badge count-badge">{{selectedCount}} {{t.kind}}</view>
  </view>

  <view class="search-wrap">
    <input class="input search-input" placeholder="{{t.search}}" value="{{search}}" bindinput="onSearch" />
  </view>

  <view class="layout">
    <scroll-view class="category-panel" scroll-y>
      <view wx:for="{{categories}}" wx:key="id" class="category-item {{activeCategory == item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="chooseCategory">
        <text class="cat-icon">{{item.icon}}</text>
        <text class="cat-name">{{item.name}}</text>
      </view>
    </scroll-view>

    <scroll-view class="ingredient-panel" scroll-y>
      <view wx:if="{{!visibleIngredients.length}}" class="empty card">{{t.noMatch}}</view>
      <view wx:for="{{visibleIngredients}}" wx:key="id" class="ingredient-card {{item.selected ? 'active' : ''}}">
        <view class="emoji">{{item.emoji}}</view>
        <view class="name-wrap">
          <view class="name">{{item.name}}</view>
          <view wx:if="{{item.quantity > 0}}" class="muted qty-hint">{{item.quantity}} {{t.total}}</view>
        </view>
        <view class="counter">
          <view wx:if="{{item.quantity > 0}}" class="counter-btn minus" data-id="{{item.id}}" catchtap="minus">-</view>
          <text wx:if="{{item.quantity > 0}}" class="quantity">{{item.quantity}}</text>
          <view class="counter-btn plus" data-id="{{item.id}}" catchtap="add">+</view>
        </view>
      </view>
      <view class="bottom-space"></view>
    </scroll-view>
  </view>

  <view class="submit-bar">
    <view class="submit-top">
      <button class="ghost-btn clear-btn" bindtap="clearSelected">{{t.clear}}</button>
      <button class="primary-btn submit-btn" bindtap="submitIngredients">{{t.submit}}</button>
    </view>
    <view class="submit-info">
      <view class="submit-title">{{t.selected}} {{selectedCount}} {{t.kind}} / {{selectedTotal}} {{t.total}}</view>
      <view class="muted submit-tip">{{t.comboTip}}</view>
    </view>
  </view>
</view>
