.menu-page { height: 100vh; padding-bottom: 138rpx; overflow: hidden; background: linear-gradient(180deg,#fff2df,#fffaf6); }
.top-strip { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; padding: 30rpx 26rpx 20rpx; }
.top-copy { flex: 1; min-width: 0; }
.page-title { font-size: 42rpx; font-weight: 950; letter-spacing: 1rpx; line-height: 1.18; }
.top-icon { width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border-radius: 24rpx; background: #fff; font-size: 38rpx; box-shadow: 0 10rpx 24rpx rgba(155,91,37,.08); }
.menu-layout { display: flex; height: calc(100vh - 204rpx); gap: 14rpx; padding-left: 18rpx; }
.category-panel { width: 140rpx; height: 100%; flex-shrink: 0; padding: 10rpx 0 24rpx; }
.category-item { min-height: 92rpx; box-sizing: border-box; display: flex; flex-direction: column; gap: 6rpx; align-items: center; justify-content: center; margin-bottom: 14rpx; padding: 12rpx 8rpx; border-radius: 28rpx; color: #8b7a70; background: rgba(255,255,255,.78); font-size: 22rpx; line-height: 1.15; box-shadow: 0 8rpx 18rpx rgba(155,91,37,.06); }
.category-item.active { color: #fff; background: linear-gradient(135deg,#ff9b3d,#ff5725); font-weight: 950; box-shadow: 0 14rpx 28rpx rgba(255,90,31,.22); }
.cat-icon { width: 46rpx; height: 46rpx; display: flex; align-items: center; justify-content: center; border-radius: 16rpx; background: rgba(255,255,255,.75); font-size: 30rpx; line-height: 46rpx; }
.cat-name { white-space: nowrap; }
.recipe-panel { flex: 1; min-width: 0; height: 100%; padding: 10rpx 18rpx 24rpx 0; }
.recipe-card { display: flex; gap: 16rpx; padding: 20rpx; margin-bottom: 18rpx; border-radius: 30rpx; background: #fff; box-shadow: 0 14rpx 30rpx rgba(155,91,37,.08); }
.cover { width: 96rpx; height: 96rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border-radius: 28rpx; color: #ff5a1f; background: linear-gradient(145deg,#fff7ee,#ffe6d1); font-size: 32rpx; font-weight: 950; }
.recipe-main { flex: 1; min-width: 0; }
.recipe-name { font-size: 30rpx; font-weight: 950; line-height: 1.25; }
.recipe-desc { margin-top: 8rpx; color: #8a7b72; font-size: 24rpx; line-height: 1.45; }
.tags { display: flex; gap: 10rpx; margin-top: 12rpx; flex-wrap: wrap; }
.recipe-action { display: flex; align-items: center; justify-content: space-between; gap: 10rpx; margin-top: 16rpx; }
.counter { display: inline-flex; align-items: center; gap: 8rpx; flex-shrink: 0; padding: 6rpx; border-radius: 24rpx; background: #fff7ef; }
.counter-btn { width: 44rpx; height: 44rpx; display: flex; align-items: center; justify-content: center; flex: 0 0 44rpx; box-sizing: border-box; border-radius: 15rpx; font-size: 30rpx; line-height: 44rpx; font-weight: 950; text-align: center; }
.counter-btn.plus { color: #fff; background: linear-gradient(135deg,#ff9b3d,#ff5725); box-shadow: 0 8rpx 18rpx rgba(255,90,31,.24); }
.counter-btn.minus { color: #ff5a1f; background: #fff; box-shadow: inset 0 0 0 2rpx #ffd9c3; }
.quantity { min-width: 30rpx; color: #ff5a1f; text-align: center; font-size: 26rpx; font-weight: 950; }
.cart-bar { position: fixed; left: 26rpx; right: 26rpx; bottom: 30rpx; display: flex; align-items: center; gap: 18rpx; padding: 18rpx; border-radius: 999rpx; background: rgba(47,43,42,.94); box-shadow: 0 18rpx 42rpx rgba(0,0,0,.20); }
.cart-bubble { position: relative; width: 76rpx; height: 76rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border-radius: 50%; background: #fff; color: #ff5a1f; font-size: 34rpx; font-weight: 950; }
.cart-count { position: absolute; right: -4rpx; top: -6rpx; min-width: 32rpx; height: 32rpx; padding: 0 8rpx; border-radius: 999rpx; color: #fff; background: #ff3b20; font-size: 20rpx; line-height: 32rpx; text-align: center; }
.cart-info { flex: 1; min-width: 0; }
.cart-title { color: #fff; font-size: 31rpx; font-weight: 950; white-space: nowrap; }
.cart-muted { color: #d7cbc5; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.checkout-btn { height: 72rpx; min-width: 148rpx; padding: 0 28rpx; border-radius: 999rpx; color: #fff; background: linear-gradient(135deg, #ff9b3d, #ff5725); font-size: 28rpx; font-weight: 950; white-space: nowrap; flex-shrink: 0; }
.checkout-btn.disabled { color: #ddd; background: #6a6260; }
.one-line { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bottom-space { height: 130rpx; }
