<view class="menu-page"><view class="top-strip"><view class="top-copy"><view class="page-title">{{t.title}}</view><view class="muted">{{t.subtitle}}</view></view><view class="top-icon">{{t.menuIcon}}</view></view><view class="menu-layout"><scroll-view class="category-panel" scroll-y><view wx:for="{{categories}}" wx:key="id" class="category-item {{activeCategory === item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="chooseCategory"><text class="cat-icon">{{item.icon}}</text><text class="cat-name">{{item.name}}</text></view></scroll-view><scroll-view class="recipe-panel" scroll-y><block wx:for="{{recipes}}" wx:key="id"><view wx:if="{{item.categoryId === activeCategory}}" class="recipe-card"><view class="cover">{{item.cover}}</view><view class="recipe-main"><view class="recipe-name">{{item.name}}</view><view class="recipe-desc">{{item.desc}}</view><view class="tags"><text wx:for="{{item.tags}}" wx:key="*this" class="badge">{{item}}</text></view><view class="recipe-action"><view class="muted one-line">{{item.ingredients.length}} {{t.kindFood}}</view><view class="counter"><view wx:if="{{item.quantity > 0}}" class="counter-btn minus" data-id="{{item.id}}" bindtap="minus">?</view><text wx:if="{{item.quantity > 0}}" class="quantity">{{item.quantity}}</text><view class="counter-btn plus" data-id="{{item.id}}" bindtap="add">+</view></view></view></view></view></block><view class="bottom-space"></view></scroll-view></view><view class="cart-bar"><view class="cart-bubble">{{t.cartIcon}}<text wx:if="{{cartCount > 0}}" class="cart-count">{{cartCount}}</text></view><view class="cart-info"><view class="cart-title">{{t.picked}} {{cartCount}} {{t.portion}}</view><view class="muted cart-muted">{{t.notify}}</view></view><button class="checkout-btn {{cartCount ? '' : 'disabled'}}" bindtap="goCart">{{t.confirm}}</button></view></view>
