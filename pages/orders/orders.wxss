.orders-page { padding-bottom: calc(210rpx + env(safe-area-inset-bottom)); }
.head { padding: 30rpx; background: linear-gradient(145deg,#fff,#fff3e8); }
.head-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx; }
.title { margin-bottom: 10rpx; font-size: 42rpx; font-weight: 950; }
.mode-btn { width: 128rpx; height: 66rpx; flex-shrink: 0; }
.head-actions { display: flex; gap: 16rpx; margin-top: 22rpx; }
.batch-btn { flex: 1; height: 76rpx; font-size: 27rpx; }
.clear-btn { width: 132rpx; height: 76rpx; }
.empty { margin-top: 28rpx; padding: 70rpx 36rpx; text-align: center; }
.empty-title { margin-bottom: 22rpx; font-size: 34rpx; font-weight: 900; }
.empty-actions { display: flex; gap: 18rpx; }
.empty-btn { flex: 1; height: 78rpx; }
.order-card { margin-top: 22rpx; padding: 24rpx; transition: all .22s ease; }
.order-card.expanded { box-shadow: 0 22rpx 48rpx rgba(255,90,31,.14); }
.order-main { display: flex; align-items: center; gap: 16rpx; }
.select-dot { width: 46rpx; height: 46rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border-radius: 50%; color: #fff; background: #fff7ef; box-shadow: inset 0 0 0 3rpx #ffd9c3; font-size: 24rpx; font-weight: 950; }
.select-dot.checked { background: linear-gradient(135deg,#ff9b3d,#ff5725); box-shadow: 0 8rpx 18rpx rgba(255,90,31,.18); }
.order-body { flex: 1; min-width: 0; }
.order-head { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; margin-bottom: 16rpx; }
.order-type { color: #ff5a1f; font-size: 32rpx; font-weight: 950; }
.order-time { color: #9a8272; font-size: 23rpx; white-space: nowrap; }
.order-items { color: #342820; font-size: 29rpx; font-weight: 850; line-height: 1.55; word-break: break-all; }
.meta-row { display: flex; gap: 12rpx; flex-wrap: wrap; margin-top: 18rpx; }
.badge.light { color: #6f8a45; background: #f1ffe5; }
.detail-box { margin-top: 22rpx; padding-top: 22rpx; border-top: 1rpx solid #f4eee8; animation: orderExpand .22s ease-out both; }
@keyframes orderExpand { from { opacity: 0; transform: translateY(-10rpx); } to { opacity: 1; transform: translateY(0); } }
.detail-section { margin-bottom: 22rpx; }
.detail-title { margin-bottom: 12rpx; color: #8a6753; font-size: 25rpx; font-weight: 950; }
.user-line { display: flex; align-items: center; gap: 16rpx; padding: 18rpx; border-radius: 24rpx; background: #fff8f1; }
.user-avatar { width: 72rpx; height: 72rpx; border-radius: 22rpx; flex-shrink: 0; }
.text-avatar { display: flex; align-items: center; justify-content: center; color: #ff5a1f; background: #fff; font-size: 36rpx; font-weight: 950; }
.user-main { flex: 1; min-width: 0; }
.user-name { font-size: 29rpx; font-weight: 950; }
.user-id { word-break: break-all; }
.content-row { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; padding: 16rpx 18rpx; margin-bottom: 10rpx; border-radius: 20rpx; background: #fffaf6; color: #342820; font-size: 28rpx; font-weight: 850; }
.row-desc { color: #ff5a1f; font-weight: 950; }
.remark { padding: 16rpx 18rpx; border-radius: 20rpx; background: #fffaf6; }
.detail-actions { display: flex; justify-content: flex-end; }
.danger-btn { color: #d83b20; background: #fff0ec; }
