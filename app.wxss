page { min-height: 100%; background: linear-gradient(180deg, #fff2df 0%, #fff8f0 38%, #fffaf6 100%); color: #30251f; font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif; }
button { box-sizing: border-box; padding: 0; margin: 0; border: 0; background: transparent; line-height: 1.2; }
button::after { border: 0; }
.container { min-height: 100vh; box-sizing: border-box; padding: 30rpx 26rpx calc(210rpx + env(safe-area-inset-bottom)); }
.card { border-radius: 36rpx; background: rgba(255,255,255,.94); box-shadow: 0 18rpx 42rpx rgba(144, 83, 33, .10); border: 1rpx solid rgba(255,255,255,.72); }
.section-title { display: flex; align-items: center; justify-content: space-between; margin: 38rpx 6rpx 18rpx; font-size: 34rpx; font-weight: 950; letter-spacing: .5rpx; }
.muted { color: #8b7a70; font-size: 24rpx; line-height: 1.55; }
.badge { display: inline-flex; align-items: center; padding: 9rpx 18rpx; border-radius: 999rpx; color: #d9541b; background: #fff0e5; font-size: 22rpx; font-weight: 850; }
.primary-btn { height: 88rpx; display: flex; align-items: center; justify-content: center; border-radius: 999rpx; color: #fff; background: linear-gradient(135deg, #ff9b3d, #ff5725); font-size: 30rpx; font-weight: 950; white-space: nowrap; box-shadow: 0 16rpx 30rpx rgba(255, 90, 31, .24); }
.ghost-btn { height: 66rpx; display: inline-flex; align-items: center; justify-content: center; padding: 0 28rpx; border-radius: 999rpx; color: #e65b20; background: #fff0e7; font-size: 26rpx; font-weight: 850; white-space: nowrap; }
.empty { padding: 70rpx 30rpx; text-align: center; color: #999; }
.input { min-height: 84rpx; box-sizing: border-box; padding: 0 28rpx; border-radius: 24rpx; background: rgba(255,255,255,.96); font-size: 28rpx; box-shadow: inset 0 0 0 1rpx #f3e3d7; }
